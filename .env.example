# ============================================================================
# UltraPlan — VisQuanta Blog Portal
# Copy this file to .env.local and fill in real values. .env.local is
# gitignored. Never commit real keys.
# ============================================================================

# ----------------------------------------------------------------------------
# LLM providers — per spec §2 principle 5 (best model at every step)
# ----------------------------------------------------------------------------
# OpenRouter — used for Nano Banana Pro image generation and as the multi-model
# gateway for GPT-5 judge calls.
OPENROUTER_API_KEY=

# Anthropic — Claude Opus 4.6 is the primary drafter (outline, paragraph
# drafting, voice transform). Spec §5b/5c/5d.
ANTHROPIC_API_KEY=

# OpenAI — GPT-5 is the fact-recheck + originality judge. Spec §6 gates b/d.
# Also used for embeddings if the rephrase-distance check chooses the
# remote-embedding path over local @xenova/transformers.
OPENAI_API_KEY=

# Voyage AI — required by lib/stages/rephrase-distance.ts for paragraph/quote
# similarity checks.
VOYAGE_API_KEY=

# ----------------------------------------------------------------------------
# Scraping — spec §3 stage 2 + §5a bundle assembly
# ----------------------------------------------------------------------------
# Firecrawl — primary trade-press scraper, allowlist-enforced via
# config/sources.yaml.
FIRECRAWL_API_KEY=

# Apify — reddit and LinkedIn dealer-principal scraping for the weekly
# authority lane.
APIFY_API_TOKEN=
# APIFY_TOKEN= also works as an alias for local scripts.

# Optional: apply cached Reddit/Google Trends boosts during resolver ranking.
# Leave off unless you want Apify discovery influencing scheduled topic choice.
ULTRAPLAN_DISCOVERY_SIGNALS=0

# Optional: enable AI-generated blog hero images. Default automation uses
# curated site assets to avoid synthetic dealership renders in daily posts.
ULTRAPLAN_ENABLE_AI_HERO_IMAGES=0

# Replicate — Flux Schnell image generation for blog hero images.
REPLICATE_API_TOKEN=

# Pexels — stock-photo fallback/options in the current image pipeline.
PEXELS_API_KEY=

# ----------------------------------------------------------------------------
# Storage — spec §5a (bundles) + §8 (rejection log) + Phase 3 state
# ----------------------------------------------------------------------------
# Supabase — run history, blocked drafts, rejection log persistence.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Vercel Blob — research bundles, failed-draft preservation.
BLOB_READ_WRITE_TOKEN=

# ----------------------------------------------------------------------------
# GitHub — spec §8 PR creation + merge/close webhook
# ----------------------------------------------------------------------------
# Personal Access Token for visquanta-dev with repo scope.
# Used to create branches and PRs on visquanta-dev/site.
GITHUB_PAT=

# Shared secret validating incoming webhook payloads from GitHub.
GITHUB_WEBHOOK_SECRET=

# Required if the legacy Vercel cron route is invoked manually. Scheduled runs
# should use GitHub Actions, not Vercel Cron.
CRON_SECRET=

# ----------------------------------------------------------------------------
# Admin dashboard — spec §8 admin views
# ----------------------------------------------------------------------------
# Single-user basic auth gate for /admin. Phase 3 work.
ADMIN_BASIC_AUTH_USER=
ADMIN_BASIC_AUTH_PASS=

# ----------------------------------------------------------------------------
# Notifications — spec §8 failure-mode escalation
# ----------------------------------------------------------------------------
# Slack webhook for PR creation failures and other critical escalations.
SLACK_WEBHOOK_URL=

# n8n webhook used by .github/workflows/daily-blog.yml for run notifications.
N8N_BLOG_WEBHOOK_URL=

# Optional Ahrefs integration used by topic enrichment when enabled.
AHREFS_API_TOKEN=
